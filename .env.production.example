# Production environment overrides.
# Loaded when APP_ENV=production (after .env).
#
# Setup:
#   1. cp .env.production.example .env.production
#   2. Set APP_ENV=production on the server (never commit real secrets)

APP_ENV=production
APP_DEBUG=false
APP_NAME=Overtime Request App
APP_URL=https://your-server.example/overtime
APP_BASE_PATH=/overtime

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=
DB_PASS=
DB_CHARSET=utf8mb4
DB_DEFAULT=webjmr

DB_WEBJMR_NAME=webjmrdb
DB_KDTPH_NAME=kdtphdb
DB_KDTPHNEW_NAME=kdtphdb_new
DB_FORMS_NAME=forms_db

MAIL_ENABLED=true
MAIL_HOST=mail01.khi.co.jp
MAIL_PORT=25
MAIL_FROM_EMAIL=kdt-ph_overtime@global.kawasaki.com
MAIL_FROM_NAME=Overtime Request App
MAIL_REPLY_TO=
MAIL_TEST_RECIPIENT=
