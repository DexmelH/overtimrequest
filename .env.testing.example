# Testing environment overrides.
# Loaded automatically when APP_ENV=testing (after .env).
#
# Setup:
#   1. cp .env.testing.example .env.testing
#   2. Set APP_ENV=testing in .env  (or: set APP_ENV=testing before running PHP)
#   3. Create test databases (see DB_*_NAME below)
#
# Switch back to local: set APP_ENV=local in .env

# ------------------------------------------------------------------------------
# Application
# ------------------------------------------------------------------------------
APP_ENV=testing
APP_DEBUG=true
APP_NAME=Overtime Request App (Testing)
APP_URL=http://localhost/overtime
APP_BASE_PATH=/overtime
APP_ADMIN_USER_IDS=

# ------------------------------------------------------------------------------
# Database — use separate test databases (never point at production data)
# ------------------------------------------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4
DB_DEFAULT=webjmr

DB_WEBJMR_NAME=webjmrdb_test
DB_KDTPH_NAME=kdtphdb_test
DB_KDTPHNEW_NAME=kdtphdb_new_test

# ------------------------------------------------------------------------------
# Mail — safe defaults for testing
# MAIL_ENABLED=false  → log only, nothing is sent
# MAIL_TEST_RECIPIENT → redirect all mail to one inbox (e.g. MailHog, Mailtrap)
# ------------------------------------------------------------------------------
MAIL_ENABLED=false
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_FROM_EMAIL=overtime-test@localhost
MAIL_FROM_NAME=Overtime Test
MAIL_REPLY_TO=
MAIL_TEST_RECIPIENT=
