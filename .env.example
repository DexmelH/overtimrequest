# Copy this file to .env and adjust values for your environment.
#   cp .env.example .env
#
# Environments (layered — base .env + .env.{APP_ENV}):
#   local       → .env only (default)
#   testing     → .env + .env.testing   (cp .env.testing.example .env.testing)
#   production  → .env + .env.production
#
# Switch without editing .env (PowerShell):
#   $env:APP_ENV="testing"; php src/usr/bin/email_worker.php
#
# Or set APP_ENV=testing in .env

# ------------------------------------------------------------------------------
# Application
# ------------------------------------------------------------------------------
APP_ENV=local
APP_DEBUG=false
APP_NAME=Overtime Request App
# Public URL of the app (no trailing slash)
APP_URL=http://localhost/overtime
# URL path prefix when app is not at web root (use empty string if docroot is /public)
APP_BASE_PATH=/overtime
# Comma-separated group abbreviations that are admin by default (e.g. MNG,IT,SYS)
APP_ADMIN_GROUP_ABBRS=MNG,IT,SYS

# ------------------------------------------------------------------------------
# Database
# All connections share host/user/pass; only database names differ.
# ------------------------------------------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4
DB_DEFAULT=webjmr

DB_WEBJMR_NAME=webjmrdb
DB_KDTPH_NAME=kdtphdb
DB_KDTPHNEW_NAME=kdtphdb_new
DB_FORMS_NAME=forms_db

# ------------------------------------------------------------------------------
# Mail (SMTP)
# ------------------------------------------------------------------------------
MAIL_HOST=mail01.khi.co.jp
MAIL_PORT=25
MAIL_FROM_EMAIL=kdt-ph_overtime@global.kawasaki.com
MAIL_FROM_NAME=Overtime Request App
MAIL_REPLY_TO=
MAIL_ENABLED=true
MAIL_TEST_RECIPIENT=
